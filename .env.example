# OPENAI_API_KEY is expected to be set as a system/user environment variable.
# Add any overrides here if needed.

# Optional: Azure OpenAI endpoint (default: https://ai-proxy.lab.epam.com)
# AZURE_OPENAI_ENDPOINT=https://ai-proxy.lab.epam.com

# Optional: Azure OpenAI API version (default: 2024-10-21)
# AZURE_OPENAI_API_VERSION=2024-10-21

# Model deployments (chat + embedding). Defaults shown; uncomment to override.
# LLM_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small-1
